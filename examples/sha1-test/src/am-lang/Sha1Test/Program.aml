namespace Sha1Test {

    // Hashes a handful of inputs and prints the hex digest. The first two
    // are the FIPS 180 SHA-1 test vectors; the last is the canonical
    // "fox" sample from RFC 3174. Expected:
    //   ""        → da39a3ee5e6b4b0d3255bfef95601890afd80709
    //   "abc"     → a9993e364706816aba3e25717850c26c9cd0d89d
    //   "fox..."  → 2fd4e1c67a2d28fced849ee1bb76e7391b93eb12
    class Program {
        import Am.Lang
        import Am.Crypto

        static fun main() {
            Program.hashAndPrint("")
            Program.hashAndPrint("abc")
            Program.hashAndPrint("AmLang")
            Program.hashAndPrint("The quick brown fox jumps over the lazy dog")
        }

        // Encode `digest` as a lower-case hex string.
        static fun toHex(digest: UByte[]): String {
            var hex: String = ""
            var i: UInt = 0UI
            while (i < digest.length()) {
                var b: UByte = digest[i]
                var hi: UInt = (b.toUInt() >> 4UI) & 0xFUI
                var lo: UInt = b.toUInt() & 0xFUI
                hex = hex + Program.nibble(hi) + Program.nibble(lo)
                i = i + 1UI
            }
            return hex
        }

        static fun nibble(n: UInt): String {
            if (n < 10UI) {
                return n.toString()
            }
            if (n == 10UI) { return "a" }
            if (n == 11UI) { return "b" }
            if (n == 12UI) { return "c" }
            if (n == 13UI) { return "d" }
            if (n == 14UI) { return "e" }
            return "f"
        }

        static fun hashAndPrint(input: String) {
            var bytes: UByte[] = input.toBytes("UTF-8")
            var digest: UByte[] = Sha1.digest(bytes)
            ("sha1(\"" + input + "\") = " + Program.toHex(digest)).println()
        }
    }
}
