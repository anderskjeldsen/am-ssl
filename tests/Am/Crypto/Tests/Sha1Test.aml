namespace Am.Crypto.Tests {

    // Tests for `Am.Crypto.Sha1.digest`. The expected digests are the
    // canonical FIPS 180 / RFC 3174 SHA-1 test vectors — if the native
    // OpenSSL/AmiSSL binding regresses, these go red immediately.
    //
    // We compare digests as lower-case hex strings rather than as byte
    // arrays, since AmLang's Assert.assertEquals doesn't deep-compare
    // primitive arrays. The hex encoding lives inline in this test file
    // so it isn't part of the library's public surface.
    class Sha1Test {
        import Am.Lang
        import Am.Crypto
        import Am.Tests

        // FIPS 180 Appendix A.1 — the empty string.
        test digestOfEmptyString() {
            var hex: String = Sha1Test.hashHex("")
            Assert.assertEquals("da39a3ee5e6b4b0d3255bfef95601890afd80709", hex)
        }

        // FIPS 180 Appendix A.2 — "abc".
        test digestOfAbc() {
            var hex: String = Sha1Test.hashHex("abc")
            Assert.assertEquals("a9993e364706816aba3e25717850c26c9cd0d89d", hex)
        }

        // RFC 3174 §7.3 sample 3 — the "fox" pangram.
        test digestOfPangram() {
            var hex: String = Sha1Test.hashHex("The quick brown fox jumps over the lazy dog")
            Assert.assertEquals("2fd4e1c67a2d28fced849ee1bb76e7391b93eb12", hex)
        }

        // A single-byte input — exercises the short-message path and
        // confirms the digest is 20 bytes (40 hex chars) regardless of
        // input length.
        test digestOfSingleByte() {
            var hex: String = Sha1Test.hashHex("a")
            Assert.assertEquals("86f7e437faa5a7fce15d1ddcb9eaeaea377667b8", hex)
            Assert.assertTrue(hex.length() == 40)
        }

        // The digest must always be exactly 20 bytes (160 bits), no matter
        // what the input is.
        test digestLengthIsAlways20Bytes() {
            var d1: UByte[] = Sha1.digest("".toBytes("UTF-8"))
            var d2: UByte[] = Sha1.digest("hello".toBytes("UTF-8"))
            var d3: UByte[] = Sha1.digest("a much longer input string than the others here".toBytes("UTF-8"))
            Assert.assertTrue(d1.length() == 20UI)
            Assert.assertTrue(d2.length() == 20UI)
            Assert.assertTrue(d3.length() == 20UI)
        }

        // Same input must always produce the same digest. Catches state
        // leakage in the native binding (e.g. a forgotten init).
        test digestIsDeterministic() {
            var first: String = Sha1Test.hashHex("AmLang")
            var second: String = Sha1Test.hashHex("AmLang")
            Assert.assertEquals(first, second)
        }

        // A flipped bit in the input produces a totally different digest
        // (avalanche). We don't measure bit distance, just inequality.
        test digestChangesWithInput() {
            var a: String = Sha1Test.hashHex("abc")
            var b: String = Sha1Test.hashHex("abd")
            Assert.assertTrue(a != b)
        }

        // Encode a digest array as a lower-case hex string. Local helper
        // so tests can compare against the canonical hex vectors.
        static fun hashHex(input: String): String {
            var bytes: UByte[] = input.toBytes("UTF-8")
            var digest: UByte[] = Sha1.digest(bytes)
            var hex: String = ""
            var i: UInt = 0UI
            while (i < digest.length()) {
                var b: UByte = digest[i]
                var hi: UInt = (b.toUInt() >> 4UI) & 0xFUI
                var lo: UInt = b.toUInt() & 0xFUI
                hex = hex + Sha1Test.nibble(hi) + Sha1Test.nibble(lo)
                i = i + 1UI
            }
            return hex
        }

        static fun nibble(n: UInt): String {
            if (n < 10UI) {
                return n.toString()
            }
            if (n == 10UI) { return "a" }
            if (n == 11UI) { return "b" }
            if (n == 12UI) { return "c" }
            if (n == 13UI) { return "d" }
            if (n == 14UI) { return "e" }
            return "f"
        }
    }
}
